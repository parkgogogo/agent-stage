{
  "name": "@agentstage/render",
  "version": "0.2.6",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/parkgogogo/agent-stage"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentstage-render-serve": "./dist/serve-cli.js"
  },
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./agent-kit": {
      "types": "./dist/agent-kit.d.ts",
      "default": "./dist/agent-kit.js"
    },
    "./serve": {
      "types": "./dist/serve.d.ts",
      "default": "./dist/serve.js"
    }
  },
  "dependencies": {
    "@agentstage/bridge": "workspace:*"
  },
  "peerDependencies": {
    "@json-render/core": "^0.7.0",
    "@json-render/react": "^0.7.0",
    "@json-render/shadcn": "^0.7.0",
    "react": ">=18",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@json-render/core": "0.7.0",
    "@json-render/react": "0.7.0",
    "@json-render/shadcn": "^0.7.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
